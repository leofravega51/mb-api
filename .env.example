NODE_ENV=development
PORT=3000

# PostgreSQL (use DATABASE_URL or individual vars)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mybusiness
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_NAME=mybusiness

# Run migrations automatically on app start (optional)
# En desarrollo conviene true para no olvidar migrar tras levantar Postgres
RUN_MIGRATIONS_ON_START=true

# JWT tenant users
JWT_SECRET=change-me-tenant-jwt
JWT_EXPIRES_IN=7d
COOKIE_MAX_AGE=604800000

# JWT platform admin
ADMIN_JWT_SECRET=dev-admin-secret-change-in-production
ADMIN_JWT_EXPIRES_IN=8h

# Seed único — platform admin (solo si la tabla está vacía)
ADMIN_EMAIL=admin@mybusiness.com
ADMIN_PASSWORD=admin123
ADMIN_NAME=Platform Admin

# CORS
CORS_ORIGIN=http://localhost:5173

# Frontend reset password URL (tenant auth)
FRONTEND_RESET_PASSWORD_URL=http://localhost:5173/recover-password
